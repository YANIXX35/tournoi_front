{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/fju.jpg",
          "/hero-bg.jpg",
          "/**/*.jpg",
          "/**/*.jpeg",
          "/**/*.png",
          "/**/*.webp",
          "/**/*.svg",
          "/**/*.woff2"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-public",
      "urls": ["/api/matches", "/api/results", "/api/teams"],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "5m",
        "timeout": "10s",
        "strategy": "freshness"
      }
    }
  ]
}
